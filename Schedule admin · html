<!DOCTYPE html>
<html lang="zh-TW">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<meta name="color-scheme" content="dark">
<meta name="theme-color" content="#080a0f">
<title>APEX SCHEDULE — 後台管理</title>
<link href="https://fonts.googleapis.com/css2?family=Rajdhani:wght@400;500;600;700&family=Noto+Sans+TC:wght@300;400;500;700&family=JetBrains+Mono:wght@400;600&display=swap" rel="stylesheet">
<style>
:root {
  color-scheme: dark;
  --bg:       #080a0f;
  --s1:       #0e1119;
  --s2:       #131720;
  --s3:       #1a1f2e;
  --border:   #1e2535;
  --border2:  #252d40;
  --text:     #c4cad8;
  --text-dim: #4a5470;
  --text-mid: #7a85a0;
  --accent:   #e8a020;
  --accent2:  #f0c040;
  --danger:   #e05050;
  --success:  #40c870;

  --E-bg:  #0f2010; --E-txt: #4dcc62; --E-bdr: #1e4020;
  --M-bg:  #0f1828; --M-txt: #4a8ff0; --M-bdr: #1a2e50;
  --N-bg:  #160f28; --N-txt: #9f6eee; --N-bdr: #2e1a50;
  --O-bg:  #0c0e12; --O-txt: #333a50; --O-bdr: #141820;

  --sidebar-w: 220px;
}

* { box-sizing: border-box; margin: 0; padding: 0; }
html, body { background: var(--bg) !important; color: var(--text); font-family: 'Noto Sans TC', sans-serif; height: 100%; }

/* ══ LAYOUT ══════════════════════════════════════════════ */
.app { display: flex; height: 100vh; overflow: hidden; }

/* ── SIDEBAR ── */
.sidebar {
  width: var(--sidebar-w);
  background: var(--s1);
  border-right: 1px solid var(--border);
  display: flex; flex-direction: column;
  flex-shrink: 0;
  z-index: 50;
}
.sidebar-logo {
  padding: 24px 20px 20px;
  border-bottom: 1px solid var(--border);
}
.logo-top {
  font-family: 'Rajdhani', sans-serif;
  font-size: 22px; font-weight: 700;
  letter-spacing: 4px; color: var(--accent);
  text-transform: uppercase;
}
.logo-sub {
  font-size: 10px; color: var(--text-dim);
  letter-spacing: 2px; margin-top: 3px;
  text-transform: uppercase;
}
.sidebar-nav { flex: 1; padding: 12px 0; }
.nav-section {
  font-size: 9px; color: var(--text-dim);
  letter-spacing: 2px; padding: 14px 20px 6px;
  text-transform: uppercase;
}
.nav-item {
  display: flex; align-items: center; gap: 10px;
  padding: 10px 20px; cursor: pointer;
  font-size: 13px; color: var(--text-mid);
  transition: all .15s; border-left: 2px solid transparent;
  user-select: none;
}
.nav-item:hover { background: var(--s2); color: var(--text); }
.nav-item.active {
  background: rgba(232,160,32,.08);
  color: var(--accent); border-left-color: var(--accent);
}
.nav-icon { font-size: 16px; width: 20px; text-align: center; }
.sidebar-footer {
  padding: 16px 20px;
  border-top: 1px solid var(--border);
  font-size: 11px; color: var(--text-dim);
}
.version-badge {
  display: inline-block;
  background: var(--s3); border: 1px solid var(--border2);
  padding: 3px 8px; border-radius: 4px;
  font-family: 'JetBrains Mono', monospace;
  font-size: 10px; color: var(--text-dim);
}

/* ── MAIN CONTENT ── */
.main { flex: 1; display: flex; flex-direction: column; overflow: hidden; }

.topbar {
  display: flex; align-items: center; justify-content: space-between;
  padding: 0 24px; height: 56px;
  background: var(--s1); border-bottom: 1px solid var(--border);
  flex-shrink: 0;
}
.topbar-title {
  font-family: 'Rajdhani', sans-serif;
  font-size: 18px; font-weight: 600;
  letter-spacing: 2px; color: #fff;
}
.topbar-actions { display: flex; gap: 10px; align-items: center; }

.content { flex: 1; overflow-y: auto; padding: 24px; }

/* ══ BUTTONS ═════════════════════════════════════════════ */
.btn {
  display: inline-flex; align-items: center; gap: 6px;
  padding: 8px 16px; border-radius: 6px; border: none;
  font-size: 12px; font-family: 'Noto Sans TC', sans-serif;
  cursor: pointer; transition: all .15s; font-weight: 500;
  letter-spacing: .5px; white-space: nowrap;
}
.btn-primary { background: var(--accent); color: #000; }
.btn-primary:hover { background: var(--accent2); }
.btn-ghost { background: var(--s3); color: var(--text); border: 1px solid var(--border2); }
.btn-ghost:hover { background: var(--border2); }
.btn-danger { background: rgba(224,80,80,.15); color: var(--danger); border: 1px solid rgba(224,80,80,.3); }
.btn-danger:hover { background: rgba(224,80,80,.25); }
.btn-success { background: rgba(64,200,112,.12); color: var(--success); border: 1px solid rgba(64,200,112,.3); }
.btn-success:hover { background: rgba(64,200,112,.22); }
.btn-sm { padding: 5px 10px; font-size: 11px; }

/* ══ PAGE: 排班表 ════════════════════════════════════════ */
#page-schedule { display: block; }
#page-employees, #page-shifts, #page-export { display: none; }

.schedule-toolbar {
  display: flex; align-items: center; justify-content: space-between;
  margin-bottom: 20px; flex-wrap: wrap; gap: 12px;
}
.month-nav { display: flex; align-items: center; gap: 12px; }
.month-nav-btn {
  background: var(--s3); border: 1px solid var(--border2);
  color: var(--text); width: 32px; height: 32px;
  border-radius: 6px; cursor: pointer; font-size: 16px;
  display: flex; align-items: center; justify-content: center;
  transition: all .15s;
}
.month-nav-btn:hover { color: var(--accent); border-color: var(--accent); }
.month-display {
  font-family: 'Rajdhani', sans-serif;
  font-size: 24px; font-weight: 700; color: #fff;
  min-width: 170px; text-align: center; letter-spacing: 2px;
}

.table-scroll { overflow-x: auto; border-radius: 10px; border: 1px solid var(--border); }
table { border-collapse: collapse; min-width: 900px; width: 100%; }

thead th {
  background: var(--s2); padding: 10px 6px;
  font-size: 11px; color: var(--text-dim); text-align: center;
  border: 1px solid var(--border); font-weight: 500; letter-spacing: .5px;
}
thead th.emp-hd {
  background: var(--s1); min-width: 110px;
  position: sticky; left: 0; z-index: 10;
}
thead th .dn { font-family: 'Rajdhani', sans-serif; font-size: 17px; font-weight: 700; color: var(--text); display: block; }
thead th.today-hd .dn { color: var(--accent); }
thead th.today-hd { background: rgba(232,160,32,.07); }
thead th .dw { font-size: 10px; }
thead th.wknd .dw { color: #d05050; }

tbody td {
  border: 1px solid var(--border);
  padding: 4px; text-align: center;
  min-width: 44px; height: 46px; vertical-align: middle;
}
tbody td.emp-cell {
  position: sticky; left: 0; z-index: 5;
  background: var(--s2); padding: 8px 12px; text-align: left;
  min-width: 110px;
}
.emp-nm { font-size: 13px; font-weight: 500; color: var(--text); white-space: nowrap; }
.emp-ps { font-size: 10px; color: var(--text-dim); margin-top: 1px; }

tbody tr:hover td { background: rgba(255,255,255,.015); }
tbody tr:hover td.emp-cell { background: #181e2c; }
td.today-hd { background: rgba(232,160,32,.06) !important; }

.chip {
  display: inline-flex; align-items: center; justify-content: center;
  width: 36px; height: 30px; border-radius: 5px;
  font-family: 'Rajdhani', sans-serif; font-size: 14px; font-weight: 700;
  cursor: pointer; transition: filter .15s, transform .1s;
  border: 1px solid; user-select: none;
}
.chip:hover { filter: brightness(1.4); transform: scale(1.1); }
.chip-E { background: var(--E-bg); color: var(--E-txt); border-color: var(--E-bdr); }
.chip-M { background: var(--M-bg); color: var(--M-txt); border-color: var(--M-bdr); }
.chip-N { background: var(--N-bg); color: var(--N-txt); border-color: var(--N-bdr); }
.chip-O { background: var(--O-bg); color: var(--O-txt); border-color: var(--O-bdr); font-size: 11px; }

td.stats-cell { min-width: 76px; padding: 6px 10px; text-align: left; }
.sc-row { display: flex; justify-content: space-between; font-size: 10px; margin-bottom: 1px; }
.sc-lbl { color: var(--text-dim); }
.sc-val { font-family: 'Rajdhani', monospace; font-weight: 700; font-size: 12px; }

.summary-row {
  display: flex; gap: 12px; margin-top: 20px; flex-wrap: wrap;
}
.sum-card {
  display: flex; align-items: center; gap: 10px;
  padding: 10px 18px; background: var(--s2);
  border: 1px solid var(--border); border-radius: 8px;
}
.sum-dot { width: 8px; height: 8px; border-radius: 50%; }
.sum-lbl { font-size: 11px; color: var(--text-dim); }
.sum-val { font-family: 'Rajdhani', sans-serif; font-size: 24px; font-weight: 700; margin-left: 4px; }

/* ══ PAGE: 員工管理 ══════════════════════════════════════ */
.emp-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(260px, 1fr)); gap: 14px; }
.emp-card {
  background: var(--s2); border: 1px solid var(--border);
  border-radius: 10px; padding: 18px;
  display: flex; flex-direction: column; gap: 12px;
  transition: border-color .15s;
}
.emp-card:hover { border-color: var(--border2); }
.emp-card-top { display: flex; align-items: center; gap: 12px; }
.emp-avatar {
  width: 44px; height: 44px; border-radius: 10px;
  background: var(--s3); border: 1px solid var(--border2);
  display: flex; align-items: center; justify-content: center;
  font-size: 20px; flex-shrink: 0;
}
.emp-card-name { font-size: 15px; font-weight: 500; color: #fff; }
.emp-card-pos {
  font-size: 11px; color: var(--text-dim);
  margin-top: 3px; letter-spacing: .5px;
}
.emp-card-info { font-size: 12px; color: var(--text-mid); }
.emp-card-actions { display: flex; gap: 8px; margin-top: 4px; }

.add-emp-form {
  background: var(--s2); border: 1px solid var(--border);
  border-radius: 10px; padding: 20px; margin-bottom: 20px;
}
.form-title {
  font-family: 'Rajdhani', sans-serif; font-size: 16px;
  font-weight: 600; letter-spacing: 1px; color: var(--accent);
  margin-bottom: 16px;
}
.form-row { display: flex; gap: 12px; flex-wrap: wrap; margin-bottom: 12px; }
.form-group { display: flex; flex-direction: column; gap: 5px; flex: 1; min-width: 140px; }
.form-label { font-size: 11px; color: var(--text-dim); letter-spacing: 1px; text-transform: uppercase; }
.form-input {
  background: var(--s1); border: 1px solid var(--border2);
  color: var(--text); padding: 8px 12px; border-radius: 6px;
  font-size: 13px; font-family: 'Noto Sans TC', sans-serif;
  outline: none; transition: border-color .15s;
}
.form-input:focus { border-color: var(--accent); }
select.form-input option { background: var(--s1); }

/* ══ PAGE: 班別設定 ══════════════════════════════════════ */
.shift-cards { display: grid; grid-template-columns: repeat(auto-fill, minmax(280px, 1fr)); gap: 16px; }
.shift-card {
  background: var(--s2); border: 1px solid var(--border);
  border-radius: 10px; padding: 20px;
}
.shift-card-header {
  display: flex; align-items: center; gap: 12px; margin-bottom: 16px;
}
.shift-preview {
  width: 48px; height: 40px; border-radius: 8px;
  display: flex; align-items: center; justify-content: center;
  font-family: 'Rajdhani', sans-serif; font-size: 18px; font-weight: 700;
  border: 1px solid;
}
.shift-card-name { font-size: 15px; font-weight: 500; color: #fff; }
.shift-card-time { font-size: 12px; color: var(--text-dim); margin-top: 3px; font-family: 'JetBrains Mono', monospace; }
.shift-field { margin-bottom: 10px; }

/* ══ PAGE: 匯出 ══════════════════════════════════════════ */
.export-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(300px, 1fr)); gap: 16px; }
.export-card {
  background: var(--s2); border: 1px solid var(--border);
  border-radius: 10px; padding: 24px;
}
.export-icon { font-size: 36px; margin-bottom: 12px; }
.export-title { font-size: 16px; font-weight: 500; color: #fff; margin-bottom: 6px; }
.export-desc { font-size: 12px; color: var(--text-dim); line-height: 1.6; margin-bottom: 18px; }
.export-options { display: flex; flex-direction: column; gap: 8px; margin-bottom: 16px; }
.radio-row { display: flex; align-items: center; gap: 8px; font-size: 13px; cursor: pointer; }
.radio-row input { accent-color: var(--accent); }

/* ══ MODAL ═══════════════════════════════════════════════ */
.overlay {
  display: none; position: fixed; inset: 0;
  background: rgba(0,0,0,.65); z-index: 200;
  align-items: center; justify-content: center;
}
.overlay.open { display: flex; }
.modal {
  background: var(--s2); border: 1px solid var(--border2);
  border-radius: 12px; padding: 24px; min-width: 240px;
  box-shadow: 0 24px 60px rgba(0,0,0,.7);
  animation: popIn .18s ease;
}
@keyframes popIn { from { transform: scale(.92); opacity: 0; } to { transform: scale(1); opacity: 1; } }
.modal-title { font-size: 11px; color: var(--text-dim); letter-spacing: 1px; text-transform: uppercase; margin-bottom: 4px; }
.modal-sub { font-family: 'Rajdhani', sans-serif; font-size: 18px; font-weight: 700; color: #fff; margin-bottom: 20px; }
.modal-opts { display: flex; flex-direction: column; gap: 8px; }
.modal-opt {
  display: flex; align-items: center; gap: 12px;
  padding: 10px 14px; border-radius: 8px;
  cursor: pointer; transition: background .15s;
  border: 1px solid transparent;
}
.modal-opt:hover { border-color: var(--border); background: rgba(255,255,255,.03); }
.opt-chip {
  width: 40px; height: 34px; border-radius: 6px;
  display: flex; align-items: center; justify-content: center;
  font-family: 'Rajdhani', sans-serif; font-size: 15px; font-weight: 700;
  border: 1px solid; flex-shrink: 0;
}
.opt-nm { font-size: 13px; font-weight: 500; color: var(--text); }
.opt-tm { font-size: 11px; color: var(--text-dim); margin-top: 2px; font-family: 'JetBrains Mono', monospace; }
.modal-cancel {
  margin-top: 14px; width: 100%; background: none;
  border: 1px solid var(--border); color: var(--text-dim);
  padding: 8px; border-radius: 8px; cursor: pointer;
  font-size: 13px; transition: background .15s;
}
.modal-cancel:hover { background: rgba(255,255,255,.03); }

/* ══ TOAST ═══════════════════════════════════════════════ */
.toast {
  position: fixed; bottom: 24px; right: 24px;
  background: var(--s3); border: 1px solid var(--border2);
  color: var(--text); padding: 12px 20px; border-radius: 8px;
  font-size: 13px; z-index: 999;
  transform: translateY(80px); opacity: 0;
  transition: all .3s cubic-bezier(.34,1.56,.64,1);
  pointer-events: none;
}
.toast.show { transform: translateY(0); opacity: 1; }
.toast.success { border-color: rgba(64,200,112,.4); color: var(--success); }

/* ══ CONFIRM DIALOG ══════════════════════════════════════ */
.confirm-btns { display: flex; gap: 10px; margin-top: 20px; justify-content: flex-end; }

/* scrollbar */
::-webkit-scrollbar { width: 6px; height: 6px; }
::-webkit-scrollbar-track { background: transparent; }
::-webkit-scrollbar-thumb { background: var(--border2); border-radius: 3px; }

@media (max-width: 768px) {
  .sidebar { width: 56px; }
  .sidebar-logo, .logo-sub, .nav-section, .nav-item span, .sidebar-footer { display: none; }
  .nav-item { justify-content: center; padding: 14px; }
  .nav-icon { width: auto; }
  .content { padding: 14px; }
}
</style>
</head>
<body>
<div class="app">

  <!-- SIDEBAR -->
  <aside class="sidebar">
    <div class="sidebar-logo">
      <div class="logo-top">APEX</div>
      <div class="logo-sub">Schedule Admin</div>
    </div>
    <nav class="sidebar-nav">
      <div class="nav-section">主功能</div>
      <div class="nav-item active" onclick="showPage('schedule',this)">
        <span class="nav-icon">📅</span><span>排班表</span>
      </div>
      <div class="nav-item" onclick="showPage('employees',this)">
        <span class="nav-icon">👥</span><span>員工管理</span>
      </div>
      <div class="nav-section">設定</div>
      <div class="nav-item" onclick="showPage('shifts',this)">
        <span class="nav-icon">⚙️</span><span>班別設定</span>
      </div>
      <div class="nav-section">工具</div>
      <div class="nav-item" onclick="showPage('export',this)">
        <span class="nav-icon">📤</span><span>匯出 / 列印</span>
      </div>
    </nav>
    <div class="sidebar-footer">
      <span class="version-badge">v1.0.0</span>
    </div>
  </aside>

  <!-- MAIN -->
  <div class="main">
    <!-- TOPBAR -->
    <div class="topbar">
      <div class="topbar-title" id="topbarTitle">排班表管理</div>
      <div class="topbar-actions" id="topbarActions">
        <button class="btn btn-ghost btn-sm" onclick="goToday()">📍 本月</button>
        <button class="btn btn-primary btn-sm" onclick="showPage('export',null)">📤 匯出</button>
      </div>
    </div>

    <!-- CONTENT -->
    <div class="content">

      <!-- ── PAGE: 排班表 ── -->
      <div id="page-schedule">
        <div class="schedule-toolbar">
          <div class="month-nav">
            <button class="month-nav-btn" onclick="changeMonth(-1)">‹</button>
            <div class="month-display" id="monthDisplay"></div>
            <button class="month-nav-btn" onclick="changeMonth(1)">›</button>
          </div>
          <div style="display:flex;gap:8px;">
            <button class="btn btn-ghost btn-sm" onclick="autoFill()">🎲 隨機填入</button>
            <button class="btn btn-ghost btn-sm" onclick="clearMonth()">🗑 清空本月</button>
          </div>
        </div>
        <div class="table-scroll"><table id="scheduleTable"></table></div>
        <div class="summary-row" id="summaryRow"></div>
      </div>

      <!-- ── PAGE: 員工管理 ── -->
      <div id="page-employees">
        <div class="add-emp-form">
          <div class="form-title">＋ 新增員工</div>
          <div class="form-row">
            <div class="form-group">
              <label class="form-label">姓名</label>
              <input class="form-input" id="inp-name" placeholder="王小明" />
            </div>
            <div class="form-group">
              <label class="form-label">職位</label>
              <select class="form-input" id="inp-pos">
                <option>組長</option>
                <option>副組長</option>
                <option>隊員</option>
              </select>
            </div>
            <div class="form-group">
              <label class="form-label">員工編號</label>
              <input class="form-input" id="inp-id" placeholder="e07" />
            </div>
          </div>
          <button class="btn btn-primary" onclick="addEmployee()">新增員工</button>
        </div>
        <div class="emp-grid" id="empGrid"></div>
      </div>

      <!-- ── PAGE: 班別設定 ── -->
      <div id="page-shifts">
        <div class="shift-cards" id="shiftCards"></div>
      </div>

      <!-- ── PAGE: 匯出 ── -->
      <div id="page-export">
        <div class="export-grid">
          <div class="export-card">
            <div class="export-icon">📊</div>
            <div class="export-title">匯出 CSV</div>
            <div class="export-desc">將當月排班表匯出為 CSV 檔案，可用 Excel 開啟進行進一步處理或存檔。</div>
            <div class="export-options">
              <label class="radio-row"><input type="radio" name="csv-scope" value="month" checked> 當月完整排班</label>
              <label class="radio-row"><input type="radio" name="csv-scope" value="emp"> 依員工匯出</label>
            </div>
            <button class="btn btn-success" onclick="exportCSV()">⬇ 下載 CSV</button>
          </div>
          <div class="export-card">
            <div class="export-icon">🖨</div>
            <div class="export-title">列印排班表</div>
            <div class="export-desc">開啟列印視窗，可直接列印或另存為 PDF，適合張貼公告使用。</div>
            <div style="margin-bottom:16px;"></div>
            <button class="btn btn-primary" onclick="printSchedule()">🖨 列印 / 存PDF</button>
          </div>
          <div class="export-card">
            <div class="export-icon">📋</div>
            <div class="export-title">班次統計摘要</div>
            <div class="export-desc">顯示當月各員工早中夜班次統計，可複製或截圖。</div>
            <div style="margin-bottom:16px;"></div>
            <button class="btn btn-ghost" onclick="showStats()">📈 查看統計</button>
          </div>
        </div>
        <div id="statsTable" style="margin-top:24px;"></div>
      </div>

    </div><!-- /content -->
  </div><!-- /main -->
</div><!-- /app -->

<!-- SHIFT PICKER MODAL -->
<div class="overlay" id="overlay" onclick="closeModal(event)">
  <div class="modal">
    <div class="modal-title">選擇班別</div>
    <div class="modal-sub" id="modalSub"></div>
    <div class="modal-opts" id="modalOpts"></div>
    <button class="modal-cancel" onclick="closeModal()">取消</button>
  </div>
</div>

<!-- CONFIRM MODAL -->
<div class="overlay" id="confirmOverlay">
  <div class="modal">
    <div class="modal-title">確認操作</div>
    <div class="modal-sub" id="confirmMsg"></div>
    <div class="confirm-btns">
      <button class="btn btn-ghost" onclick="document.getElementById('confirmOverlay').classList.remove('open')">取消</button>
      <button class="btn btn-danger" id="confirmOkBtn">確認刪除</button>
    </div>
  </div>
</div>

<!-- TOAST -->
<div class="toast" id="toast"></div>

<script>
// ═══════════════════════════════════════════════════════
//  DATA STORE
// ═══════════════════════════════════════════════════════
let employees = [
  { id:'e01', name:'王志明', pos:'組長',  avatar:'👮' },
  { id:'e02', name:'陳建宏', pos:'隊員',  avatar:'👤' },
  { id:'e03', name:'林淑芬', pos:'隊員',  avatar:'👤' },
  { id:'e04', name:'黃俊傑', pos:'隊員',  avatar:'👤' },
  { id:'e05', name:'吳雅婷', pos:'隊員',  avatar:'👤' },
  { id:'e06', name:'張文凱', pos:'隊員',  avatar:'👤' },
];

let shiftDefs = {
  E: { label:'早', name:'早班', start:'06:00', end:'14:00', bg:'var(--E-bg)', txt:'var(--E-txt)', bdr:'var(--E-bdr)' },
  M: { label:'中', name:'中班', start:'14:00', end:'22:00', bg:'var(--M-bg)', txt:'var(--M-txt)', bdr:'var(--M-bdr)' },
  N: { label:'夜', name:'夜班', start:'22:00', end:'06:00', bg:'var(--N-bg)', txt:'var(--N-txt)', bdr:'var(--N-bdr)' },
  O: { label:'休', name:'休假', start:'',      end:'',      bg:'var(--O-bg)', txt:'var(--O-txt)', bdr:'var(--O-bdr)' },
};

let schedule = {}; // key: empId_YYYY-MM-DD → 'E'|'M'|'N'|'O'
let pendingCell = null;

const today = new Date();
let curYear  = today.getFullYear();
let curMonth = today.getMonth() + 1;

const DAYS_TW = ['日','一','二','三','四','五','六'];

// ═══════════════════════════════════════════════════════
//  NAV
// ═══════════════════════════════════════════════════════
const pageTitles = {
  schedule:  ['排班表管理',  `<button class="btn btn-ghost btn-sm" onclick="goToday()">📍 本月</button><button class="btn btn-primary btn-sm" onclick="showPage('export',null)">📤 匯出</button>`],
  employees: ['員工管理',    `<button class="btn btn-primary btn-sm" onclick="document.getElementById('inp-name').focus()">＋ 新增員工</button>`],
  shifts:    ['班別設定',    ''],
  export:    ['匯出 / 列印', ''],
};

function showPage(name, el) {
  ['schedule','employees','shifts','export'].forEach(p => {
    document.getElementById('page-'+p).style.display = 'none';
  });
  document.getElementById('page-'+name).style.display = 'block';
  document.querySelectorAll('.nav-item').forEach(n => n.classList.remove('active'));
  if (el) el.classList.add('active');
  else {
    document.querySelectorAll('.nav-item').forEach(n => {
      if (n.onclick && n.onclick.toString().includes("'"+name+"'")) n.classList.add('active');
    });
  }
  document.getElementById('topbarTitle').textContent = pageTitles[name][0];
  document.getElementById('topbarActions').innerHTML = pageTitles[name][1];

  if (name === 'employees') renderEmpGrid();
  if (name === 'shifts')    renderShiftCards();
}

// ═══════════════════════════════════════════════════════
//  SCHEDULE PAGE
// ═══════════════════════════════════════════════════════
function changeMonth(d) {
  curMonth += d;
  if (curMonth > 12) { curMonth = 1; curYear++; }
  if (curMonth < 1)  { curMonth = 12; curYear--; }
  renderSchedule();
}
function goToday() {
  curYear = today.getFullYear(); curMonth = today.getMonth()+1;
  renderSchedule();
}

function renderSchedule() {
  const days = new Date(curYear, curMonth, 0).getDate();
  document.getElementById('monthDisplay').textContent =
    `${curYear} / ${String(curMonth).padStart(2,'0')}`;

  // thead
  let thead = `<thead><tr><th class="emp-hd">人員</th>`;
  for (let d=1; d<=days; d++) {
    const dt  = new Date(curYear, curMonth-1, d);
    const dow = dt.getDay();
    const isT = (curYear===today.getFullYear() && curMonth===today.getMonth()+1 && d===today.getDate());
    thead += `<th class="${isT?'today-hd':''} ${dow===0||dow===6?'wknd':''}">
      <span class="dn">${d}</span>
      <span class="dw">${DAYS_TW[dow]}</span>
    </th>`;
  }
  thead += `<th style="min-width:76px">統計</th></tr></thead>`;

  // tbody
  let tbody = '<tbody>';
  employees.forEach(emp => {
    let cE=0,cM=0,cN=0;
    let row = `<tr><td class="emp-cell">
      <div class="emp-nm">${emp.name}</div>
      <div class="emp-ps">${emp.pos}</div>
    </td>`;
    for (let d=1; d<=days; d++) {
      const ds  = `${curYear}-${String(curMonth).padStart(2,'0')}-${String(d).padStart(2,'0')}`;
      const key = `${emp.id}_${ds}`;
      const s   = schedule[key] || 'O';
      const dt  = new Date(curYear, curMonth-1, d);
      const isT = (curYear===today.getFullYear() && curMonth===today.getMonth()+1 && d===today.getDate());
      if (s==='E') cE++; else if (s==='M') cM++; else if (s==='N') cN++;
      row += `<td class="${isT?'today-hd':''}">
        <div class="chip chip-${s}" onclick="openModal('${emp.id}','${emp.name}','${ds}')">${shiftDefs[s].label}</div>
      </td>`;
    }
    row += `<td class="stats-cell">
      <div class="sc-row"><span class="sc-lbl">早</span><span class="sc-val" style="color:var(--E-txt)">${cE}</span></div>
      <div class="sc-row"><span class="sc-lbl">中</span><span class="sc-val" style="color:var(--M-txt)">${cM}</span></div>
      <div class="sc-row"><span class="sc-lbl">夜</span><span class="sc-val" style="color:var(--N-txt)">${cN}</span></div>
    </td></tr>`;
    tbody += row;
  });
  tbody += '</tbody>';

  document.getElementById('scheduleTable').innerHTML = thead + tbody;
  renderSummary();
}

function renderSummary() {
  const days = new Date(curYear, curMonth, 0).getDate();
  let tE=0,tM=0,tN=0,tO=0;
  employees.forEach(emp => {
    for (let d=1; d<=days; d++) {
      const key = `${emp.id}_${curYear}-${String(curMonth).padStart(2,'0')}-${String(d).padStart(2,'0')}`;
      const s = schedule[key]||'O';
      if(s==='E')tE++; else if(s==='M')tM++; else if(s==='N')tN++; else tO++;
    }
  });
  document.getElementById('summaryRow').innerHTML = `
    <div class="sum-card"><div class="sum-dot" style="background:var(--E-txt)"></div><span class="sum-lbl">早班</span><span class="sum-val" style="color:var(--E-txt)">${tE}</span></div>
    <div class="sum-card"><div class="sum-dot" style="background:var(--M-txt)"></div><span class="sum-lbl">中班</span><span class="sum-val" style="color:var(--M-txt)">${tM}</span></div>
    <div class="sum-card"><div class="sum-dot" style="background:var(--N-txt)"></div><span class="sum-lbl">夜班</span><span class="sum-val" style="color:var(--N-txt)">${tN}</span></div>
    <div class="sum-card"><div class="sum-dot" style="background:var(--text-dim)"></div><span class="sum-lbl">休假</span><span class="sum-val" style="color:var(--text-dim)">${tO}</span></div>
  `;
}

function autoFill() {
  const days = new Date(curYear, curMonth, 0).getDate();
  const pool = ['E','M','N','O','O'];
  employees.forEach(emp => {
    for (let d=1; d<=days; d++) {
      const key = `${emp.id}_${curYear}-${String(curMonth).padStart(2,'0')}-${String(d).padStart(2,'0')}`;
      schedule[key] = pool[Math.floor(Math.random()*pool.length)];
    }
  });
  renderSchedule();
  toast('已隨機填入本月排班', 'success');
}

function clearMonth() {
  confirmDialog('確定清空本月所有排班？', () => {
    const days = new Date(curYear, curMonth, 0).getDate();
    employees.forEach(emp => {
      for (let d=1; d<=days; d++) {
        const key = `${emp.id}_${curYear}-${String(curMonth).padStart(2,'0')}-${String(d).padStart(2,'0')}`;
        schedule[key] = 'O';
      }
    });
    renderSchedule();
    toast('已清空本月排班');
  });
}

// ═══════════════════════════════════════════════════════
//  MODAL
// ═══════════════════════════════════════════════════════
function openModal(empId, empName, dateStr) {
  pendingCell = { empId, dateStr };
  document.getElementById('modalSub').textContent = `${empName}・${dateStr}`;
  const opts = Object.entries(shiftDefs).map(([k,v]) => `
    <div class="modal-opt" onclick="selectShift('${k}')">
      <div class="opt-chip chip-${k}">${v.label}</div>
      <div>
        <div class="opt-nm">${v.name}</div>
        <div class="opt-tm">${v.start}${v.end ? ' – '+v.end : ''}</div>
      </div>
    </div>`).join('');
  document.getElementById('modalOpts').innerHTML = opts;
  document.getElementById('overlay').classList.add('open');
}
function closeModal(e) {
  if (!e || e.target.id==='overlay') {
    document.getElementById('overlay').classList.remove('open');
    pendingCell = null;
  }
}
function selectShift(type) {
  if (!pendingCell) return;
  schedule[`${pendingCell.empId}_${pendingCell.dateStr}`] = type;
  document.getElementById('overlay').classList.remove('open');
  pendingCell = null;
  renderSchedule();
}

// ═══════════════════════════════════════════════════════
//  EMPLOYEE PAGE
// ═══════════════════════════════════════════════════════
function renderEmpGrid() {
  document.getElementById('empGrid').innerHTML = employees.map(emp => `
    <div class="emp-card">
      <div class="emp-card-top">
        <div class="emp-avatar">${emp.avatar}</div>
        <div>
          <div class="emp-card-name">${emp.name}</div>
          <div class="emp-card-pos">${emp.pos}</div>
        </div>
      </div>
      <div class="emp-card-info">編號：<span style="font-family:'JetBrains Mono',monospace;color:var(--accent)">${emp.id}</span></div>
      <div class="emp-card-actions">
        <button class="btn btn-danger btn-sm" onclick="deleteEmployee('${emp.id}')">🗑 刪除</button>
      </div>
    </div>`).join('');
}

function addEmployee() {
  const name = document.getElementById('inp-name').value.trim();
  const pos  = document.getElementById('inp-pos').value;
  const id   = document.getElementById('inp-id').value.trim();
  if (!name || !id) { toast('請填寫姓名和員工編號'); return; }
  if (employees.find(e => e.id === id)) { toast('員工編號已存在'); return; }
  employees.push({ id, name, pos, avatar:'👤' });
  document.getElementById('inp-name').value = '';
  document.getElementById('inp-id').value   = '';
  renderEmpGrid();
  toast(`已新增員工：${name}`, 'success');
}

function deleteEmployee(id) {
  const emp = employees.find(e => e.id===id);
  confirmDialog(`確定刪除員工「${emp.name}」？`, () => {
    employees = employees.filter(e => e.id !== id);
    renderEmpGrid();
    toast(`已刪除員工：${emp.name}`);
  });
}

// ═══════════════════════════════════════════════════════
//  SHIFT SETTINGS PAGE
// ═══════════════════════════════════════════════════════
function renderShiftCards() {
  document.getElementById('shiftCards').innerHTML = Object.entries(shiftDefs).map(([k,v]) => `
    <div class="shift-card">
      <div class="shift-card-header">
        <div class="shift-preview chip-${k}" style="background:${v.bg};color:${v.txt};border:1px solid ${v.bdr}">${v.label}</div>
        <div>
          <div class="shift-card-name">${v.name}</div>
          <div class="shift-card-time">${v.start}${v.end?' – '+v.end:''}</div>
        </div>
      </div>
      <div class="shift-field">
        <div class="form-label" style="margin-bottom:5px">班別名稱</div>
        <input class="form-input" value="${v.name}" onchange="updateShift('${k}','name',this.value)" style="width:100%"/>
      </div>
      ${k!=='O'?`
      <div class="form-row" style="gap:8px">
        <div class="form-group">
          <div class="form-label">開始時間</div>
          <input class="form-input" type="time" value="${v.start}" onchange="updateShift('${k}','start',this.value)"/>
        </div>
        <div class="form-group">
          <div class="form-label">結束時間</div>
          <input class="form-input" type="time" value="${v.end}" onchange="updateShift('${k}','end',this.value)"/>
        </div>
      </div>`:''}
    </div>`).join('');
}

function updateShift(key, field, val) {
  shiftDefs[key][field] = val;
  renderShiftCards();
  toast('班別設定已更新', 'success');
}

// ═══════════════════════════════════════════════════════
//  EXPORT
// ═══════════════════════════════════════════════════════
function exportCSV() {
  const days = new Date(curYear, curMonth, 0).getDate();
  const monthStr = `${curYear}-${String(curMonth).padStart(2,'0')}`;

  // header row
  const headers = ['員工編號','姓名','職位', ...Array.from({length:days},(_,i)=>String(i+1)+'日'), '早班數','中班數','夜班數'];
  const rows = [headers];

  employees.forEach(emp => {
    let cE=0,cM=0,cN=0;
    const row = [emp.id, emp.name, emp.pos];
    for (let d=1; d<=days; d++) {
      const key = `${emp.id}_${monthStr}-${String(d).padStart(2,'0')}`;
      const s = schedule[key]||'O';
      row.push(shiftDefs[s].name);
      if(s==='E')cE++; else if(s==='M')cM++; else if(s==='N')cN++;
    }
    row.push(cE,cM,cN);
    rows.push(row);
  });

  const csv = '\uFEFF' + rows.map(r => r.map(c => `"${c}"`).join(',')).join('\n');
  const blob = new Blob([csv], { type:'text/csv;charset=utf-8;' });
  const url  = URL.createObjectURL(blob);
  const a    = document.createElement('a');
  a.href = url; a.download = `排班表_${monthStr}.csv`;
  a.click(); URL.revokeObjectURL(url);
  toast('CSV 已下載', 'success');
}

function printSchedule() {
  window.print();
}

function showStats() {
  const days = new Date(curYear, curMonth, 0).getDate();
  const monthStr = `${curYear}-${String(curMonth).padStart(2,'0')}`;
  let html = `<div style="background:var(--s2);border:1px solid var(--border);border-radius:10px;padding:20px;">
    <div style="font-family:'Rajdhani',sans-serif;font-size:18px;font-weight:700;color:#fff;margin-bottom:16px;letter-spacing:2px">${curYear}年${curMonth}月 班次統計</div>
    <table style="width:100%;border-collapse:collapse">
      <thead><tr>
        <th style="text-align:left;padding:8px 12px;border-bottom:1px solid var(--border);color:var(--text-dim);font-size:12px">姓名</th>
        <th style="padding:8px;border-bottom:1px solid var(--border);color:var(--E-txt);font-size:12px">早班</th>
        <th style="padding:8px;border-bottom:1px solid var(--border);color:var(--M-txt);font-size:12px">中班</th>
        <th style="padding:8px;border-bottom:1px solid var(--border);color:var(--N-txt);font-size:12px">夜班</th>
        <th style="padding:8px;border-bottom:1px solid var(--border);color:var(--text-dim);font-size:12px">休假</th>
        <th style="padding:8px;border-bottom:1px solid var(--border);color:var(--accent);font-size:12px">上班天數</th>
      </tr></thead><tbody>`;
  employees.forEach(emp => {
    let cE=0,cM=0,cN=0,cO=0;
    for (let d=1; d<=days; d++) {
      const s = schedule[`${emp.id}_${monthStr}-${String(d).padStart(2,'0')}`]||'O';
      if(s==='E')cE++; else if(s==='M')cM++; else if(s==='N')cN++; else cO++;
    }
    html += `<tr>
      <td style="padding:8px 12px;font-size:13px">${emp.name} <span style="color:var(--text-dim);font-size:11px">${emp.pos}</span></td>
      <td style="padding:8px;text-align:center;font-family:'Rajdhani',sans-serif;font-weight:700;color:var(--E-txt)">${cE}</td>
      <td style="padding:8px;text-align:center;font-family:'Rajdhani',sans-serif;font-weight:700;color:var(--M-txt)">${cM}</td>
      <td style="padding:8px;text-align:center;font-family:'Rajdhani',sans-serif;font-weight:700;color:var(--N-txt)">${cN}</td>
      <td style="padding:8px;text-align:center;font-family:'Rajdhani',sans-serif;font-weight:700;color:var(--text-dim)">${cO}</td>
      <td style="padding:8px;text-align:center;font-family:'Rajdhani',sans-serif;font-weight:700;color:var(--accent)">${cE+cM+cN}</td>
    </tr>`;
  });
  html += '</tbody></table></div>';
  document.getElementById('statsTable').innerHTML = html;
  toast('統計已產生', 'success');
}

// ═══════════════════════════════════════════════════════
//  UTILITIES
// ═══════════════════════════════════════════════════════
function toast(msg, type='') {
  const el = document.getElementById('toast');
  el.textContent = msg;
  el.className = 'toast' + (type ? ' '+type : '');
  el.classList.add('show');
  setTimeout(() => el.classList.remove('show'), 2800);
}

function confirmDialog(msg, onOk) {
  document.getElementById('confirmMsg').textContent = msg;
  document.getElementById('confirmOverlay').classList.add('open');
  const btn = document.getElementById('confirmOkBtn');
  btn.onclick = () => {
    document.getElementById('confirmOverlay').classList.remove('open');
    onOk();
  };
}

// ═══════════════════════════════════════════════════════
//  INIT
// ═══════════════════════════════════════════════════════
renderSchedule();
</script>
</body>
</html>
